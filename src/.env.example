# ============================================
# Money Personal Tracking - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# 
# VITE_ prefix is required by Vite for client-side env vars
# These variables are embedded at build time

# Base URL for the backend REST API
# Example: https://api.moneytracking.com/api
VITE_API_URL=https://yourbackend.com/api

# Secret API key for server-to-server authentication
# Sent as: Authorization: Bearer <VITE_API_KEY>
VITE_API_KEY=your_secret_key
